PORT=5000
MONGODB_URI=mongodb://localhost:27017/stint-db
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
NODE_ENV=development
# Comma-separated list of allowed origins for CORS. Use '*' to allow all origins (not recommended for production).
CORS_ORIGIN=http://localhost:5174,http://localhost:5173

# Frontend API Base URL (for reference, frontend uses VITE_API_BASE_URL)
VITE_API_BASE_URL=http://localhost:5000/api